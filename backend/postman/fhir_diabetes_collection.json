{
  "info": {
    "_postman_id": "c0b7bcde-cbce-4c17-875a-37c7d7f5e341",
    "name": "FHIR Diabetes Interoperability Bridge",
    "description": "Demo flow: 1. Login to store {{token}}. 2. GET /patients and pick an external patient. 3. POST /patients/{{patient_id}}/authorize. 4. POST /patients/{{patient_id}}/import. 5. GET /patients/{{patient_id}}/chart to verify data appears. 6. DELETE /patients/{{patient_id}}/data to reset the demo.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "description": "Step 1: login as a seeded clinician account. This request stores the returned JWT into {{token}} automatically.",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"doctor1@clinic.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/login",
          "host": ["{{base_url}}"],
          "path": ["auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const response = pm.response.json();",
              "if (response.token) {",
              "  pm.collectionVariables.set('token', response.token);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "description": "Basic API health check.",
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Get Current User",
      "request": {
        "method": "GET",
        "description": "Returns the currently authenticated user from the JWT token.",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/auth/me",
          "host": ["{{base_url}}"],
          "path": ["auth", "me"]
        }
      }
    },
    {
      "name": "Get Patients",
      "request": {
        "method": "GET",
        "description": "Step 2: list patients and pick an external patient id for the demo flow.",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/patients",
          "host": ["{{base_url}}"],
          "path": ["patients"]
        }
      }
    },
    {
      "name": "Get Patient",
      "request": {
        "method": "GET",
        "description": "Fetch one patient record including import flags.",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/patients/{{patient_id}}",
          "host": ["{{base_url}}"],
          "path": ["patients", "{{patient_id}}"]
        }
      }
    },
    {
      "name": "Authorize Patient Source",
      "request": {
        "method": "POST",
        "description": "Step 3: authorize an external patient to connect mock Athena or Epic data.",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"source\": \"athena\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/patients/{{patient_id}}/authorize",
          "host": ["{{base_url}}"],
          "path": ["patients", "{{patient_id}}", "authorize"]
        }
      }
    },
    {
      "name": "Import Patient Data",
      "request": {
        "method": "POST",
        "description": "Step 4: import mock data for an authorized external patient. No request body is required. Re-running this request overwrites the patient's prior imported demo data instead of duplicating it.",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/patients/{{patient_id}}/import",
          "host": ["{{base_url}}"],
          "path": ["patients", "{{patient_id}}", "import"]
        }
      }
    },
    {
      "name": "Get Patient Summary",
      "request": {
        "method": "GET",
        "description": "Return lightweight dashboard summary stats for the selected patient.",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/patients/{{patient_id}}/summary",
          "host": ["{{base_url}}"],
          "path": ["patients", "{{patient_id}}", "summary"]
        }
      }
    },
    {
      "name": "Get Patient Chart",
      "request": {
        "method": "GET",
        "description": "Step 5: fetch the UI-friendly chart payload. Before import, arrays should be empty for external patients. After import, chart data should appear and the banner should say Data imported from Athena or Epic.",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/patients/{{patient_id}}/chart",
          "host": ["{{base_url}}"],
          "path": ["patients", "{{patient_id}}", "chart"]
        }
      }
    },
    {
      "name": "Get Patient FHIR Bundle",
      "request": {
        "method": "GET",
        "description": "Export all stored FHIR resources for the selected patient as a FHIR Bundle.",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/patients/{{patient_id}}/fhir",
          "host": ["{{base_url}}"],
          "path": ["patients", "{{patient_id}}", "fhir"]
        }
      }
    },
    {
      "name": "Create Doctor Note",
      "request": {
        "method": "POST",
        "description": "Create a clinical note for the selected patient.",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"note\": \"Patient reports improved glucose control over the last month.\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/patients/{{patient_id}}/notes",
          "host": ["{{base_url}}"],
          "path": ["patients", "{{patient_id}}", "notes"]
        }
      }
    },
    {
      "name": "Import EMR Data",
      "request": {
        "method": "POST",
        "description": "Generic EMR import endpoint that converts simple EMR-style JSON into stored FHIR resources.",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"George Burdell\",\n  \"patient_id\": {{patient_id}},\n  \"a1c\": 7.4,\n  \"medications\": [\"Metformin\"],\n  \"diagnosis\": \"Type 2 Diabetes Mellitus\",\n  \"note\": \"Imported follow-up note from simulated Athena feed\",\n  \"source_system\": \"Athena\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/emr/import",
          "host": ["{{base_url}}"],
          "path": ["emr", "import"]
        }
      }
    },
    {
      "name": "Clear Patient Data",
      "request": {
        "method": "DELETE",
        "description": "Step 6: clear imported patient data and reset the demo flags.",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/patients/{{patient_id}}/data",
          "host": ["{{base_url}}"],
          "path": ["patients", "{{patient_id}}", "data"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:5000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "patient_id",
      "value": "1"
    }
  ]
}
