# Choose one DATABASE_URL and comment out the other.

# SQLite fallback for zero-setup local usage
DATABASE_URL=sqlite:///fhir_diabetes_bridge.db

# Persistent PostgreSQL via Docker
# DATABASE_URL=postgresql://fhir:fhir@localhost:5432/fhir_bridge

# Auto-seed only when the database is empty
AUTO_SEED=true

# Optional secrets for local development
SECRET_KEY=replace-me-with-a-long-random-secret
JWT_SECRET_KEY=replace-me-with-a-long-random-jwt-secret
