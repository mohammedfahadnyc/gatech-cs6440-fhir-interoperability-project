# Persistent PostgreSQL via Docker
DATABASE_URL=postgresql://fhir:fhir@localhost:5432/fhir_bridge

# Auto-seed only when the database is empty
AUTO_SEED=true

# Local development secrets. Replace before real deployment.
SECRET_KEY=replace-me-with-a-long-random-secret
JWT_SECRET_KEY=replace-me-with-a-long-random-jwt-secret
FRONTEND_APP_URL=http://localhost:3000

# Optional external EHR sandbox integration
EPIC_ENABLED=false
EPIC_CLIENT_ID=
EPIC_CLIENT_SECRET=
EPIC_REDIRECT_URI=http://127.0.0.1:5000/auth/epic/callback
EPIC_FHIR_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
EPIC_AUTH_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth/
EPIC_DEMO_PATIENT_EMAILS=external.demo2@example.local,external.demo3@example.local
